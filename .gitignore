cat > .gitignore << 'EOF'
__pycache__/
*.py[cod]
*.so
.Python
venv/
env/
.venv/
dist/
build/
*.egg-info/
*.egg
data/raw/*.csv
data/interim/*.csv
!data/raw/.gitkeep
!data/interim/.gitkeep
logs/
*.log
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.ipynb_checkpoints/
*.ipynb
outputs/figures/*.png
!outputs/figures/.gitkeep
outputs/reports/*.csv
!outputs/reports/.gitkeep
outputs/screenshots/*.png
!outputs/screenshots/.gitkeep
powerbi/*.csv
!powerbi/.gitkeep
Thumbs.db
Desktop.ini
.env
EOF