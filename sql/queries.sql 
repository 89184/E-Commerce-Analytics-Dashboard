-- E-COMMERCE ANALYTICS DASHBOARD - SQL QUERIES
-- Database: ecommerce_analytics
-- Table: transactions
-- ------------------------------------------------------------

----------------------------------------------- 1. SCHEMA CREATION-----------------------------------------


-- Create database (if not exists)
CREATE DATABASE IF NOT EXISTS ecommerce_analytics;
USE ecommerce_analytics;

-- Create transactions table
CREATE TABLE IF NOT EXISTS transactions (
    transaction_id VARCHAR(20) PRIMARY KEY,
    transaction_date DATE,
    customer_id VARCHAR(20),
    category VARCHAR(50),
    product_name VARCHAR(100),
    quantity INT,
    unit_price DECIMAL(10,2),
    total_amount DECIMAL(10,2),
    payment_method VARCHAR(50),
    customer_age INT,
    customer_city VARCHAR(50),
    year INT,
    month INT,
    quarter INT,
    weekday VARCHAR(20)
);

-- Create customers dimension table
CREATE TABLE IF NOT EXISTS dim_customers (
    customer_id VARCHAR(20) PRIMARY KEY,
    customer_age INT,
    customer_city VARCHAR(50),
    first_purchase_date DATE,
    total_spent DECIMAL(10,2),
    order_count INT
);

-- Create products dimension table
CREATE TABLE IF NOT EXISTS dim_products (
    product_id INT AUTO_INCREMENT PRIMARY KEY,
    category VARCHAR(50),
    product_name VARCHAR(100),
    avg_price DECIMAL(10,2),
    total_units_sold INT,
    total_revenue DECIMAL(10,2)
);

----------------------------------------- 2. BASIC KPIs-----------------------------------------------


-- Total Revenue
SELECT 
    'Total Revenue' AS Metric,
    SUM(total_amount) AS Value
FROM transactions;

-- Total Orders
SELECT 
    'Total Orders' AS Metric,
    COUNT(*) AS Value
FROM transactions;

-- Unique Customers
SELECT 
    'Unique Customers' AS Metric,
    COUNT(DISTINCT customer_id) AS Value
FROM transactions;

-- Average Order Value
SELECT 
    'Average Order Value' AS Metric,
    ROUND(AVG(total_amount), 2) AS Value
FROM transactions;

-- All KPIs in one query
SELECT 
    SUM(total_amount) AS total_revenue,
    COUNT(*) AS total_orders,
    COUNT(DISTINCT customer_id) AS unique_customers,
    ROUND(AVG(total_amount), 2) AS avg_order_value,
    SUM(quantity) AS total_items_sold
FROM transactions;

-- ----------------------------------------3. CATEGORY ANALYSIS-------------------------------------------------------


-- Revenue by Category
SELECT 
    category,
    ROUND(SUM(total_amount), 2) AS total_revenue,
    COUNT(*) AS order_count,
    ROUND(AVG(total_amount), 2) AS avg_order_value,
    ROUND(SUM(total_amount) / (SELECT SUM(total_amount) FROM transactions) * 100, 2) AS revenue_share_percent
FROM transactions
GROUP BY category
ORDER BY total_revenue DESC;

-- Category Performance with Ranking
SELECT 
    category,
    ROUND(SUM(total_amount), 2) AS total_revenue,
    COUNT(*) AS order_count,
    RANK() OVER (ORDER BY SUM(total_amount) DESC) AS revenue_rank
FROM transactions
GROUP BY category
ORDER BY revenue_rank;

-- Top 5 Categories by Revenue
SELECT 
    category,
    ROUND(SUM(total_amount), 2) AS total_revenue,
    ROUND(SUM(total_amount) / (SELECT SUM(total_amount) FROM transactions) * 100, 2) AS revenue_share
FROM transactions
GROUP BY category
ORDER BY total_revenue DESC
LIMIT 5;

-- --------------------------------------------4. MONTHLY & TIME ANALYSIS-------------------------------------------


-- Monthly Revenue Trend
SELECT 
    DATE_FORMAT(transaction_date, '%Y-%m') AS month,
    ROUND(SUM(total_amount), 2) AS monthly_revenue,
    COUNT(*) AS order_count,
    ROUND(AVG(total_amount), 2) AS avg_order_value
FROM transactions
GROUP BY month
ORDER BY month;

-- Monthly Revenue with Month-over-Month Growth
SELECT 
    DATE_FORMAT(transaction_date, '%Y-%m') AS month,
    ROUND(SUM(total_amount), 2) AS monthly_revenue,
    LAG(ROUND(SUM(total_amount), 2)) OVER (ORDER BY DATE_FORMAT(transaction_date, '%Y-%m')) AS previous_month_revenue,
    ROUND(
        ((SUM(total_amount) - LAG(SUM(total_amount)) OVER (ORDER BY DATE_FORMAT(transaction_date, '%Y-%m'))) / 
        LAG(SUM(total_amount)) OVER (ORDER BY DATE_FORMAT(transaction_date, '%Y-%m'))) * 100, 2
    ) AS growth_percent
FROM transactions
GROUP BY month
ORDER BY month;

-- Quarterly Revenue
SELECT 
    CONCAT(YEAR(transaction_date), '-Q', QUARTER(transaction_date)) AS quarter,
    ROUND(SUM(total_amount), 2) AS quarterly_revenue,
    COUNT(*) AS order_count
FROM transactions
GROUP BY quarter
ORDER BY quarter;

-- Best and Worst Months
SELECT 
    'Best Month' AS Period,
    DATE_FORMAT(transaction_date, '%Y-%m') AS month,
    ROUND(SUM(total_amount), 2) AS revenue
FROM transactions
GROUP BY month
ORDER BY revenue DESC
LIMIT 1

UNION ALL

SELECT 
    'Worst Month' AS Period,
    DATE_FORMAT(transaction_date, '%Y-%m') AS month,
    ROUND(SUM(total_amount), 2) AS revenue
FROM transactions
GROUP BY month
ORDER BY revenue ASC
LIMIT 1;

-- Daily Pattern (Day of Week)
SELECT 
    DAYNAME(transaction_date) AS day_of_week,
    COUNT(*) AS order_count,
    ROUND(SUM(total_amount), 2) AS total_revenue,
    ROUND(AVG(total_amount), 2) AS avg_order_value
FROM transactions
GROUP BY day_of_week
ORDER BY FIELD(day_of_week, 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday');

