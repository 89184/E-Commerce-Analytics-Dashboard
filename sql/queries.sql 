-- ---------------------------------------------5. PAYMENT METHOD ANALYSIS---------------------------------------


-- Payment Method Distribution
SELECT 
    payment_method,
    COUNT(*) AS transaction_count,
    ROUND(SUM(total_amount), 2) AS total_revenue,
    ROUND(AVG(total_amount), 2) AS avg_order_value,
    ROUND(COUNT(*) / (SELECT COUNT(*) FROM transactions) * 100, 2) AS share_percent
FROM transactions
GROUP BY payment_method
ORDER BY total_revenue DESC;

-- Payment Method Revenue Share
SELECT 
    payment_method,
    ROUND(SUM(total_amount), 2) AS total_revenue,
    ROUND(SUM(total_amount) / (SELECT SUM(total_amount) FROM transactions) * 100, 2) AS revenue_share
FROM transactions
GROUP BY payment_method
ORDER BY total_revenue DESC;

-- ----------------------------------------6. CUSTOMER ANALYSIS-------------------------------------------


-- Customer Lifetime Value (CLV)
SELECT 
    customer_id,
    COUNT(*) AS order_count,
    ROUND(SUM(total_amount), 2) AS total_spent,
    ROUND(AVG(total_amount), 2) AS avg_order_value,
    MIN(transaction_date) AS first_purchase,
    MAX(transaction_date) AS last_purchase
FROM transactions
GROUP BY customer_id
ORDER BY total_spent DESC
LIMIT 20;

-- Customer Acquisition by Month
SELECT 
    DATE_FORMAT(first_purchase, '%Y-%m') AS acquisition_month,
    COUNT(*) AS new_customers
FROM (
    SELECT 
        customer_id,
        MIN(transaction_date) AS first_purchase
    FROM transactions
    GROUP BY customer_id
) AS first_purchases
GROUP BY acquisition_month
ORDER BY acquisition_month;

-- Customer Segmentation - RFM Analysis
WITH customer_metrics AS (
    SELECT 
        customer_id,
        DATEDIFF((SELECT MAX(transaction_date) FROM transactions), MAX(transaction_date)) AS recency,
        COUNT(*) AS frequency,
        ROUND(SUM(total_amount), 2) AS monetary
    FROM transactions
    GROUP BY customer_id
),
rfm_scores AS (
    SELECT 
        customer_id,
        recency,
        frequency,
        monetary,
        NTILE(5) OVER (ORDER BY recency DESC) AS r_score,
        NTILE(5) OVER (ORDER BY frequency) AS f_score,
        NTILE(5) OVER (ORDER BY monetary) AS m_score
    FROM customer_metrics
),
rfm_final AS (
    SELECT 
        customer_id,
        recency,
        frequency,
        monetary,
        r_score,
        f_score,
        m_score,
        r_score + f_score + m_score AS rfm_score,
        CASE 
            WHEN r_score + f_score + m_score >= 13 THEN 'Champions'
            WHEN r_score + f_score + m_score >= 10 THEN 'Loyal Customers'
            WHEN r_score + f_score + m_score >= 7 THEN 'Potential Loyalists'
            WHEN r_score + f_score + m_score >= 4 THEN 'At Risk'
            ELSE 'Need Attention'
        END AS segment
    FROM rfm_scores
)
SELECT 
    segment,
    COUNT(*) AS customer_count,
    ROUND(AVG(recency), 1) AS avg_recency,
    ROUND(AVG(frequency), 1) AS avg_frequency,
    ROUND(AVG(monetary), 2) AS avg_monetary,
    ROUND(COUNT(*) / (SELECT COUNT(*) FROM rfm_final) * 100, 1) AS percentage
FROM rfm_final
GROUP BY segment
ORDER BY customer_count DESC;

-- City-wise Performance
SELECT 
    customer_city,
    COUNT(DISTINCT customer_id) AS customer_count,
    COUNT(*) AS order_count,
    ROUND(SUM(total_amount), 2) AS total_revenue,
    ROUND(AVG(total_amount), 2) AS avg_order_value
FROM transactions
GROUP BY customer_city
ORDER BY total_revenue DESC
LIMIT 10;

-- Age Group Analysis
SELECT 
    CASE 
        WHEN customer_age < 20 THEN 'Under 20'
        WHEN customer_age BETWEEN 20 AND 29 THEN '20-29'
        WHEN customer_age BETWEEN 30 AND 39 THEN '30-39'
        WHEN customer_age BETWEEN 40 AND 49 THEN '40-49'
        WHEN customer_age BETWEEN 50 AND 59 THEN '50-59'
        ELSE '60+'
    END AS age_group,
    COUNT(*) AS order_count,
    ROUND(SUM(total_amount), 2) AS total_revenue,
    ROUND(AVG(total_amount), 2) AS avg_order_value
FROM transactions
WHERE customer_age IS NOT NULL
GROUP BY age_group
ORDER BY age_group;

-- ----------------------------------------------------7. PRODUCT ANALYSIS--------------------------------------------


-- Top 10 Products by Revenue
SELECT 
    product_name,
    category,
    ROUND(SUM(total_amount), 2) AS total_revenue,
    COUNT(*) AS units_sold,
    ROUND(AVG(unit_price), 2) AS avg_price
FROM transactions
GROUP BY product_name, category
ORDER BY total_revenue DESC
LIMIT 10;

-- Bottom 10 Products by Revenue (Underperformers)
SELECT 
    product_name,
    category,
    ROUND(SUM(total_amount), 2) AS total_revenue,
    COUNT(*) AS units_sold,
    ROUND(AVG(unit_price), 2) AS avg_price
FROM transactions
GROUP BY product_name, category
HAVING total_revenue > 0
ORDER BY total_revenue ASC
LIMIT 10;

-- Product Performance Score (for inventory optimization)
WITH product_stats AS (
    SELECT 
        product_name,
        category,
        COUNT(*) AS units_sold,
        ROUND(SUM(total_amount), 2) AS total_revenue,
        ROUND(AVG(unit_price), 2) AS avg_price,
        ROUND(SUM(total_amount) / COUNT(*), 2) AS revenue_per_unit,
        MAX(transaction_date) AS last_sale_date
    FROM transactions
    GROUP BY product_name, category
),
performance_scaled AS (
    SELECT 
        product_name,
        category,
        units_sold,
        total_revenue,
        avg_price,
        revenue_per_unit,
        DATEDIFF((SELECT MAX(transaction_date) FROM transactions), last_sale_date) AS days_since_last_sale,
        ROUND(units_sold / (SELECT MAX(units_sold) FROM product_stats) * 100, 2) AS units_score,
        ROUND(total_revenue / (SELECT MAX(total_revenue) FROM product_stats) * 100, 2) AS revenue_score
    FROM product_stats
)
SELECT 
    product_name,
    category,
    units_sold,
    ROUND(total_revenue, 2) AS total_revenue,
    days_since_last_sale,
    CASE 
        WHEN units_score < 20 OR revenue_score < 20 THEN 'Low Performance - Consider Reducing Stock'
        WHEN units_score < 50 OR revenue_score < 50 THEN 'Medium Performance - Monitor'
        ELSE 'High Performance - Maintain Stock'
    END AS performance_tier
FROM performance_scaled
ORDER BY (units_score + revenue_score) ASC
LIMIT 20;

-- ------------------------------------------8. INVENTORY OPTIMIZATION-----------------------------


-- Slow-moving products (no sales for > 30 days)
SELECT 
    product_name,
    category,
    ROUND(SUM(total_amount), 2) AS total_revenue,
    COUNT(*) AS units_sold,
    MAX(transaction_date) AS last_sale_date,
    DATEDIFF((SELECT MAX(transaction_date) FROM transactions), MAX(transaction_date)) AS days_since_last_sale
FROM transactions
GROUP BY product_name, category
HAVING days_since_last_sale > 30
ORDER BY days_since_last_sale DESC;

-- Inventory Recommendations
SELECT 
    product_name,
    category,
    COUNT(*) AS units_sold,
    ROUND(SUM(total_amount), 2) AS total_revenue,
    CASE 
        WHEN COUNT(*) < 10 THEN 'Low Demand - Reduce Stock'
        WHEN COUNT(*) BETWEEN 10 AND 30 THEN 'Medium Demand - Maintain Stock'
        ELSE 'High Demand - Increase Stock'
    END AS inventory_recommendation
FROM transactions
GROUP BY product_name, category
ORDER BY units_sold ASC
LIMIT 20;

-- ----------------------------------------------------9. ADVANCED ANALYTICS------------------------------------------


-- Correlation: Age vs Spending
SELECT 
    customer_age,
    ROUND(AVG(total_amount), 2) AS avg_spend,
    ROUND(AVG(quantity), 2) AS avg_quantity,
    COUNT(*) AS order_count
FROM transactions
WHERE customer_age IS NOT NULL
GROUP BY customer_age
ORDER BY customer_age;

-- Cohort Analysis (Monthly Customer Retention)
WITH first_purchases AS (
    SELECT 
        customer_id,
        DATE_FORMAT(MIN(transaction_date), '%Y-%m') AS cohort_month
    FROM transactions
    GROUP BY customer_id
),
customer_orders AS (
    SELECT 
        t.customer_id,
        DATE_FORMAT(t.transaction_date, '%Y-%m') AS order_month,
        f.cohort_month,
        TIMESTAMPDIFF(MONTH, f.cohort_month, DATE_FORMAT(t.transaction_date, '%Y-%m')) AS month_number
    FROM transactions t
    JOIN first_purchases f ON t.customer_id = f.customer_id
)
SELECT 
    cohort_month,
    month_number,
    COUNT(DISTINCT customer_id) AS customers
FROM customer_orders
GROUP BY cohort_month, month_number
ORDER BY cohort_month, month_number;

-- ----------------------------------------10. VALIDATION QUERIES----------------------------------------------------


-- Check for null values
SELECT 
    'transaction_id' AS column_name, COUNT(*) - COUNT(transaction_id) AS null_count FROM transactions
UNION ALL
SELECT 'customer_id', COUNT(*) - COUNT(customer_id) FROM transactions
UNION ALL
SELECT 'product_name', COUNT(*) - COUNT(product_name) FROM transactions
UNION ALL
SELECT 'category', COUNT(*) - COUNT(category) FROM transactions
UNION ALL
SELECT 'quantity', COUNT(*) - COUNT(quantity) FROM transactions
UNION ALL
SELECT 'unit_price', COUNT(*) - COUNT(unit_price) FROM transactions
UNION ALL
SELECT 'total_amount', COUNT(*) - COUNT(total_amount) FROM transactions;

-- Check for negative values
SELECT 
    'negative_price' AS issue, COUNT(*) AS count
FROM transactions
WHERE unit_price < 0
UNION ALL
SELECT 'negative_quantity', COUNT(*)
FROM transactions
WHERE quantity < 0
UNION ALL
SELECT 'negative_total', COUNT(*)
FROM transactions
WHERE total_amount < 0;

-- Check duplicate transaction IDs
SELECT 
    transaction_id,
    COUNT(*) AS duplicate_count
FROM transactions
GROUP BY transaction_id
HAVING COUNT(*) > 1;

-- -----------------------------------------------------11. EXPORT QUERIES FOR POWER BI-------------------------------------


-- Export fact table
SELECT 
    transaction_id,
    transaction_date,
    customer_id,
    category,
    product_name,
    quantity,
    unit_price,
    total_amount,
    payment_method,
    customer_age,
    customer_city
FROM transactions;

-- Export date dimension
SELECT DISTINCT
    transaction_date AS date,
    YEAR(transaction_date) AS year,
    MONTH(transaction_date) AS month,
    MONTHNAME(transaction_date) AS month_name,
    QUARTER(transaction_date) AS quarter,
    DAYOFWEEK(transaction_date) AS day_of_week,
    DAYNAME(transaction_date) AS day_name,
    WEEK(transaction_date) AS week,
    CASE WHEN DAYOFWEEK(transaction_date) IN (1, 7) THEN 1 ELSE 0 END AS is_weekend
FROM transactions
ORDER BY transaction_date;

-- Export customer dimension
SELECT 
    customer_id,
    customer_age,
    customer_city,
    MIN(transaction_date) AS first_purchase_date,
    ROUND(SUM(total_amount), 2) AS total_spent,
    COUNT(*) AS order_count
FROM transactions
GROUP BY customer_id, customer_age, customer_city;

-- Export product dimension
SELECT 
    product_name,
    category,
    ROUND(AVG(unit_price), 2) AS avg_price,
    COUNT(*) AS total_units_sold,
    ROUND(SUM(total_amount), 2) AS total_revenue
FROM transactions
GROUP BY product_name, category;


